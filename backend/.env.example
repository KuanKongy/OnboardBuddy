NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Supabase (Settings > Data API for URL, Settings > API Keys for keys)
# URL must be the project root, e.g. https://<ref>.supabase.co — NOT /rest/v1
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Database (Settings > Database > Connection string URI, Session mode)
DATABASE_URL=

# Upstash Redis (TCP/TLS endpoint, NOT the HTTP/REST one)
REDIS_URL=
WORKER_POLL_INTERVAL_MS=5000

# GitHub OAuth App (for Supabase Auth login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App (for read-only repo import)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem

# OpenRouter (AI explanation layer)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini

# Encryption key for GitHub tokens (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
TOKEN_ENCRYPTION_KEY=
