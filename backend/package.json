{
  "name": "@onboardbuddy/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,worker -c cyan,yellow \"npm run dev:api -w backend\" \"npm run dev:worker -w backend\"",
    "dev:api": "tsx watch src/api/server.ts",
    "dev:worker": "tsx watch src/worker/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/api/server.js",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/index.js",
    "test": "node --import tsx ../node_modules/mocha/bin/mocha.js \"test/**/*.test.ts\"",
    "test:watch": "node --import tsx ../node_modules/mocha/bin/mocha.js --watch \"test/**/*.test.ts\"",
    "lint": "eslint ."
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "ioredis": "^5.6.1",
    "jose": "^6.2.3",
    "openai": "^5.1.0",
    "pg": "^8.16.0",
    "simple-git": "^3.28.0"
  },
  "devDependencies": {
    "@types/chai": "^5.2.2",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.15.29",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "chai": "^5.2.0",
    "mocha": "12.0.0-beta-9.4",
    "supertest": "^7.1.1",
    "tsx": "^4.19.4"
  }
}
